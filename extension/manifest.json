{
  "manifest_version": 3,
  "name": "ContextLens",
  "version": "0.2.0",
  "description": "AI memory and context compression for Claude, ChatGPT, Gemini, DeepSeek, Perplexity and more. Save tokens, avoid limits.",
  "permissions": [
    "storage", "tabs", "identity", "activeTab"
  ],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://chat.deepseek.com/*",
    "https://www.perplexity.ai/*",
    "https://platform.openai.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://chat.deepseek.com/*",
        "https://www.perplexity.ai/*",
        "https://platform.openai.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "ContextLens",
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["injector.js", "lib/transformers.min.js", "lib/compressor.js", "welcome.html"],
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://chat.deepseek.com/*",
        "https://www.perplexity.ai/*",
        "https://platform.openai.com/*"
      ]
    }
  ]
}


